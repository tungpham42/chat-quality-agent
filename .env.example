# =============================================================================
# Chat Quality Agent - Biến môi trường
# =============================================================================
# Sao chép file này thành .env và điền thông tin phù hợp:
#   cp .env.example .env

# --- Server ---
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
APP_ENV=production
# APP_URL=https://cqatp.example.com  # URL công khai (dùng cho links trong notification)

# --- Database (MySQL 8+) ---
DB_HOST=db
DB_PORT=3307
DB_USER=cqatp
DB_PASSWORD=       # Bắt buộc — mật khẩu MySQL cho user cqa
DB_NAME=cqatp
MYSQL_ROOT_PASSWORD=  # Bắt buộc — mật khẩu root MySQL

# --- Bảo mật (BẮT BUỘC — tạo giá trị ngẫu nhiên cho production) ---
# JWT_SECRET: chuỗi ngẫu nhiên, tối thiểu 32 ký tự
#   Tạo: openssl rand -hex 32
JWT_SECRET=

# ENCRYPTION_KEY: đúng 32 bytes cho AES-256-GCM
#   Tạo: openssl rand -hex 16
ENCRYPTION_KEY=

# --- Rate Limiting (mỗi phút) ---
RATE_LIMIT_PER_IP=500
RATE_LIMIT_PER_USER=1000

# --- SSL (tùy chọn — để trống nếu dùng HTTP) ---
# Đặt domain để tự động tạo và gia hạn SSL qua Let's Encrypt
LEGO_DOMAIN=saas.soft.io.vn
LEGO_EMAIL=soft.io.vn@gmail.com
